# 使用方式：
# 1. 复制本文件为 `.env.local`。
# 2. 只在 `.env.local` 中填写真实 base url 和 key；不要把 `.env.local` 提交到 Git。
# 3. 后端启动时会自动读取 `.env.local` / `.env`；前端只通过本地 Node API 调模型，避免在浏览器散落密钥。

# 统一模型名称。推荐使用 LLM_MODEL；MODEL_NAME 作为历史兼容别名仍可读取。
# 是否必需：可选。默认使用 gpt-5.5；如果你的网关模型名不同，可改成网关支持的名称。
# 获取方式：查看你的模型服务商或自建网关的模型列表。
LLM_MODEL=gpt-5.5

# 统一模型 API Base URL。推荐使用 LLM_BASE_URL；MODEL_BASE_URL 作为历史兼容别名仍可读取。
# 是否必需：真实模型调用必需。后端会做轻量真实探测；未配置或探测失败时，工作台不会生成假优化结果，只显示安全预览/错误提示。
# 获取方式：到模型服务商控制台或你的代理网关中复制 OpenAI-compatible base url。
# 注意：这里必须是 API Base URL，不是登录页、Token 购买页、控制台页面或网页落地页；如果 POST /chat/completions 返回 405/HTML，说明地址填错了。
# 填写示例：https://api.openai.com/v1 或 https://your-gateway.example.com/v1
LLM_BASE_URL=

# 统一模型 API Key。推荐使用 LLM_API_KEY；MODEL_API_KEY 作为历史兼容别名仍可读取。
# 是否必需：真实模型调用必需。请只写在 `.env.local`，不要写进代码或提交到 Git。
# 获取方式：在模型服务商控制台或你的模型网关后台创建 API Key。
LLM_API_KEY=

# 模型供应商标识，仅用于界面展示和运行记录。推荐使用 LLM_PROVIDER；MODEL_PROVIDER 作为历史兼容别名仍可读取。
# 是否必需：可选。默认 openai-compatible；如果你使用公司网关，可填公司/网关名称。
LLM_PROVIDER=openai-compatible

# 多模型实验候选列表，用英文逗号分隔。推荐使用 LLM_CANDIDATE_MODELS；MODEL_CANDIDATE_MODELS 作为历史兼容别名仍可读取。
# 是否必需：可选。Run Lab 多模型实验会按这里的顺序运行；默认只运行 LLM_MODEL。
# 获取方式：填写你的模型网关实际支持的模型名。
LLM_CANDIDATE_MODELS=gpt-5.5

# 模型请求超时时间，单位毫秒。
# 是否必需：可选。默认 60000；模型较慢或网关链路较长时可适当调大。
MODEL_TIMEOUT_MS=60000

# 模型默认温度。
# 是否必需：可选。默认 0.35；越低越稳定，越高越发散。
MODEL_TEMPERATURE=0.35

# 模型网关 HTTPS 证书校验。
# 是否必需：可选。默认 true。只有当你的本地/自建模型网关证书链不完整、且你明确接受开发环境风险时，才在 `.env.local` 中设置为 false。
# 获取方式：无需从服务商获取；优先修复网关证书链，临时调试才关闭。该开关只影响后端调用 MODEL_BASE_URL，不影响普通外部链接导入。
MODEL_TLS_REJECT_UNAUTHORIZED=true

# 是否打开 MCP/SDK/Tool/Connector 的本地真实执行门控。
# 是否必需：可选。默认 false。即使设置为 true，仍要求资产状态为 executable 且用户显式确认；未绑定 adapter 时只会 dry-run。
# 获取方式：本地开发调试时手动设置，不建议在不了解副作用时开启。
ENABLE_TOOL_EXECUTION=false

# MCP/SDK/Tool/Connector 真实执行 adapter 白名单，用英文逗号分隔。
# 是否必需：可选。默认只启用只读/低风险 adapter；即使白名单包含某项，也仍需要 ENABLE_TOOL_EXECUTION=true、资产 status=executable 和用户确认。
# 获取方式：从设置页 “Tool / MCP / SDK Adapter 测试台” 查看 adapter id，再按需加入。
# 可选值示例：tool.ripgrep,tool.http_get,tool.json_extract,sdk.openai.chat,mcp.stdio.call
TOOL_EXECUTION_ALLOWLIST=tool.ripgrep,tool.http_get,tool.json_extract,sdk.openai.chat

# MCP/SDK/Tool/Connector adapter 单次执行超时时间，单位毫秒。
# 是否必需：可选。默认 15000。MCP stdio 或外部 HTTP 较慢时可适当调大。
TOOL_EXECUTION_TIMEOUT_MS=15000

# 本地 Node API 监听端口。
# 是否必需：可选。默认 8787；如端口被占用，可改成其他本地端口。
# 获取方式：自行选择未被占用的本机端口。
API_PORT=8787

# 前端访问本地 Node API 的基础地址。
# 是否必需：可选。默认 http://127.0.0.1:8787；如果修改 API_PORT，需要同步修改这里。
# 获取方式：由 API_PORT 组合得到，例如 API_PORT=18787 时填写 http://127.0.0.1:18787。
VITE_API_BASE_URL=http://127.0.0.1:8787
